{
  "version": 2,
  "builds": [
    {
      "src": "api/chat.py",
      "use": "@vercel/python"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/api/health", "dest": "/api/chat" },
    { "src": "/api/chat",   "dest": "/api/chat" },
    { "src": "/(.*)",       "dest": "/public/$1" }
  ]
}
